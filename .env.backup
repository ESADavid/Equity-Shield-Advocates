# ===================================
# OSCAR BROOME REVENUE SYSTEM
# Environment Configuration Template
# ===================================

# ===== DATABASE CONFIGURATION =====
MONGODB_URI=mongodb://localhost:27017/oscar-broome-revenue
DB_HOST=localhost
DB_PORT=27017
DB_NAME=oscar-broome-revenue
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===== EMAIL CONFIGURATION =====
# Email Provider: sendgrid, ses, or smtp
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Company Name

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here

# AWS SES Configuration (if using SES)
AWS_SES_ACCESS_KEY_ID=your_aws_access_key
AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SES_REGION=us-east-1

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
SMTP_SECURE=false

# ===== SMS CONFIGURATION =====
# SMS Provider: twilio, aws-sns, or nexmo
SMS_PROVIDER=twilio
SMS_FROM_NUMBER=+1234567890

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# AWS SNS Configuration (if using SNS)
AWS_SNS_ACCESS_KEY_ID=your_aws_access_key
AWS_SNS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SNS_REGION=us-east-1

# Nexmo/Vonage Configuration (if using Nexmo)
NEXMO_API_KEY=your_nexmo_api_key
NEXMO_API_SECRET=your_nexmo_api_secret
NEXMO_FROM_NUMBER=YourCompany

# ===== APPLICATION CONFIGURATION =====
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ===== SECURITY =====
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_here

# ===== JPMORGAN CONFIGURATION =====
JPMORGAN_CLIENT_ID=your_client_id
JPMORGAN_CLIENT_SECRET=your_client_secret
JPMORGAN_MERCHANT_ID=your_merchant_id
JPMORGAN_TERMINAL_ID=your_terminal_id
JPMORGAN_BASE_URL=https://api.payments.jpmorgan.com

# ===== QUICKBOOKS CONFIGURATION =====
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_COMPANY_ID=your_company_id
QUICKBOOKS_ACCESS_TOKEN=your_access_token

# ===== PLAID CONFIGURATION =====
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# ===== LOGGING =====
LOG_LEVEL=info
