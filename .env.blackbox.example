# Blackbox.ai Multi-Agent Configuration
# Required for using the multi-agent AI task system

# API Key from https://cloud.blackbox.ai
BLACKBOX_API_KEY=your_blackbox_api_key_here

# Repository URL for AI agents to work on
BLACKBOX_REPO_URL=https://github.com/bsean/OSCAR-BROOME-REVENUE.git

# Branch to use (default: main)
BLACKBOX_BRANCH=main
