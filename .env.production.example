# Equity Shield Advocates - Production Environment Template
# Copy to a secure runtime environment file or secret manager entry set.
# Do NOT commit real production secrets.

# Server
NODE_ENV=production
PORT=8080

# JPM OAuth (PRODUCTION values only after bank approval)
JPM_OAUTH_URL=https://id.payments.jpmorgan.com/am/oauth2/alpha/access_token
JPM_CLIENT_ID=__SET_IN_SECRET_MANAGER__
JPM_CLIENT_SECRET=__SET_IN_SECRET_MANAGER__
JPM_SCOPE=jpm:payments:production
JPM_GRANT_TYPE=client_credentials

# JPM API base
JPM_API_BASE_URL=https://api.payments.jpmorgan.com

# Internal service auth
INTERNAL_API_KEY=__SET_STRONG_RANDOM_SECRET__

# Operational controls
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=15000
ENABLE_VERBOSE_ERRORS=false
DISABLE_AI_ROUTES=true
