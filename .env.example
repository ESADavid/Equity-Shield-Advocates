# JPM OAuth Configuration
# Copy to .env and fill in your values

JPM_OAUTH_URL=https://api-sandbox.payments.jpmorgan.com/oauth
JPM_CLIENT_ID=your_client_id_here
JPM_CLIENT_SECRET=your_client_secret_here
JPM_SCOPE=payments
JPM_GRANT_TYPE=client_credentials
JPM_API_BASE_URL=https://api-sandbox.payments.jpmorgan.com

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=15000
ENABLE_VERBOSE_ERRORS=true
