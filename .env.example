# =============================================================================
# OSCAR BROOME REVENUE - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your actual values
# NOTE: Never commit .env file to version control!
# =============================================================================

# Node Environment
NODE_ENV=development
PORT=3000

# =============================================================================
# JPMorgan API Configuration (REQUIRED FOR PRODUCTION)
# =============================================================================
JPMORGAN_CLIENT_ID=your_jpmorgan_client_id_here
JPMORGAN_CLIENT_SECRET=your_jpmorgan_client_secret_here
JPMORGAN_KEY_ID=your_jpmorgan_key_id_here
JPMORGAN_BASE_URL=https://api.jpmorgan.platform.bank
JPMORGAN_API_TIMEOUT=30000
JPMORGAN_DEBUG=false

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/oscar-broome
MONGODB_URI_PROD=your_production_mongodb_uri_here

# =============================================================================
# JWT & Authentication
# =============================================================================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# =============================================================================
# Email (SendGrid)
# =============================================================================
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@oscarbroome.com

# =============================================================================
# SMS (Twilio)
# =============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# Plaid API
# =============================================================================
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# =============================================================================
# Redis (Cache)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# AI Services (Optional)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
