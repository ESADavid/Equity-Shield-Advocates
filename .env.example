# ============================================
# OSCAR BROOME REVENUE SYSTEM
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control
# ============================================

# --------------------------------------------
# SERVER CONFIGURATION
# --------------------------------------------
PORT=3000
NODE_ENV=development
HOST=localhost

# --------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------
# MySQL Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=oscar_broome_revenue

# Database Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# --------------------------------------------
# SECURITY & AUTHENTICATION
# --------------------------------------------
# JWT Secret (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters

# Encryption Key (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_encryption_key_here_32_bytes_hex

# Session Secret
SESSION_SECRET=your_session_secret_here

# Password Hashing Rounds (10-12 recommended)
BCRYPT_ROUNDS=10

# --------------------------------------------
# JPMORGAN CHASE INTEGRATION
# --------------------------------------------
# JPMorgan API Credentials (Get from: https://developer.jpmorgan.com/)
JPMORGAN_CLIENT_ID=your_jpmorgan_client_id
JPMORGAN_CLIENT_SECRET=your_jpmorgan_client_secret
JPMORGAN_API_KEY=your_jpmorgan_api_key
JPMORGAN_MERCHANT_ID=your_merchant_id
JPMORGAN_TERMINAL_ID=your_terminal_id

# JPMorgan Organization & Project IDs
JPMORGAN_ORGANIZATION_ID=D3R56WRGSR3R
JPMORGAN_PROJECT_ID=DK2MQSR1FS7V

# JPMorgan API Configuration
JPMORGAN_BASE_URL=https://api.payments.jpmorgan.com
JPMORGAN_API_VERSION=v1
JPMORGAN_TIMEOUT=30000

# JPMorgan Banking Credentials
JPMORGAN_ACCOUNT_NUMBER=your_account_number
JPMORGAN_ROUTING_NUMBER=your_routing_number

# --------------------------------------------
# QUICKBOOKS INTEGRATION
# --------------------------------------------
# QuickBooks OAuth Credentials (Get from: https://developer.intuit.com/)
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/callback

# QuickBooks Company & Access
QUICKBOOKS_COMPANY_ID=your_company_id
QUICKBOOKS_ACCESS_TOKEN=your_access_token
QUICKBOOKS_REFRESH_TOKEN=your_refresh_token

# QuickBooks API Configuration
QUICKBOOKS_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_MINOR_VERSION=65

# --------------------------------------------
# STRIPE PAYMENT PROCESSING
# --------------------------------------------
# Stripe API Keys (Get from: https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --------------------------------------------
# PLAID BANKING INTEGRATION
# --------------------------------------------
# Plaid Credentials (Get from: https://dashboard.plaid.com/)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_PRODUCTS=auth,transactions,identity
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=http://localhost:3000/plaid/callback

# --------------------------------------------
# TWILIO NOTIFICATIONS
# --------------------------------------------
# Twilio Credentials (Get from: https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid

# --------------------------------------------
# EMAIL CONFIGURATION (SendGrid)
# --------------------------------------------
# SendGrid API Key (Get from: https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@oscarbroome.com
SENDGRID_FROM_NAME=Oscar Broome Revenue System

# SMTP Configuration (Alternative to SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# --------------------------------------------
# REDIS CACHE (Optional)
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# --------------------------------------------
# LOGGING CONFIGURATION
# --------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# --------------------------------------------
# RATE LIMITING
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------
# CORS CONFIGURATION
# --------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# --------------------------------------------
# BLOCKCHAIN CONFIGURATION
# --------------------------------------------
BLOCKCHAIN_DIFFICULTY=4
BLOCKCHAIN_MINING_REWARD=50

# --------------------------------------------
# AI & ANALYTICS
# --------------------------------------------
# NVIDIA Blackwell Service
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_API_ENDPOINT=https://api.nvidia.com

# OpenAI (for AI features)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# --------------------------------------------
# MONITORING & PERFORMANCE
# --------------------------------------------
# Application Performance Monitoring
APM_ENABLED=false
APM_SERVICE_NAME=oscar-broome-revenue
APM_SERVER_URL=http://localhost:8200

# Metrics Collection
METRICS_ENABLED=true
METRICS_PORT=9090

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------
ENABLE_QUANTUM_SECURITY=true
ENABLE_BLOCKCHAIN=true
ENABLE_AI_ANALYTICS=true
ENABLE_REAL_TIME_NOTIFICATIONS=true
ENABLE_MULTI_TENANT=false

# --------------------------------------------
# DEVELOPMENT & DEBUGGING
# --------------------------------------------
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_SWAGGER_DOCS=true

# --------------------------------------------
# PRODUCTION SETTINGS
# --------------------------------------------
# Set these in production environment
# FORCE_HTTPS=true
# TRUST_PROXY=true
# HELMET_ENABLED=true
# COMPRESSION_ENABLED=true

# --------------------------------------------
# BACKUP & DISASTER RECOVERY
# --------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups

# --------------------------------------------
# COMPLIANCE & AUDIT
# --------------------------------------------
PCI_COMPLIANCE_MODE=true
AUDIT_LOG_ENABLED=true
DATA_RETENTION_DAYS=2555

# ============================================
# NOTES:
# ============================================
# 1. Replace all "your_*" placeholders with actual values
# 2. Generate secure random strings for secrets
# 3. Use environment-specific values for staging/production
# 4. Never commit .env file to version control
# 5. Rotate secrets regularly (every 90 days recommended)
# 6. Use different credentials for each environment
# ============================================
