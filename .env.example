# Blackbox.ai Multi-Agent Integration
# Copy this to .env and fill in your values

# Required: Get from https://cloud.blackbox.ai → Profile → API Token
BLACKBOX_API_KEY=bb_your_api_key_here

# Optional: GitHub repo for AI agents to work on (auto-detected if omitted)
BLACKBOX_REPO_URL=https://github.com/yourusername/your-repo.git

# Optional: Git branch (default: main)
BLACKBOX_BRANCH=main

# Example usage in docs/blackbox-integration.md

