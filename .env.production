# HEAVEN ON EARTH - PRODUCTION ENVIRONMENT
# OWLBAN GROUP / House of David
# Classification: Confidential - Production Credentials

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=production
PORT=443
HOST=0.0.0.0
APP_NAME=Heaven-On-Earth
APP_VERSION=1.0.0

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Production Cluster
MONGODB_URI=mongodb+srv://admin:CHANGE_ME@heaven-on-earth-prod.mongodb.net/heaven-on-earth?retryWrites=true&w=majority
MONGODB_DB_NAME=heaven-on-earth
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10

# Redis Cache (Production)
REDIS_HOST=heaven-on-earth-redis.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_TLS=true

# ============================================
# SECURITY & ENCRYPTION
# ============================================
# JWT Secret (256-bit minimum)
JWT_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Encryption Key (AES-256)
ENCRYPTION_KEY=CHANGE_ME_TO_32_BYTE_HEX_STRING
ENCRYPTION_ALGORITHM=aes-256-cbc

# Session Secret
SESSION_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING

# API Keys Encryption
API_KEY_SALT=CHANGE_ME_TO_SECURE_SALT

# ============================================
# JPMORGAN CHASE INTEGRATION
# ============================================
JPMORGAN_API_KEY=CHANGE_ME
JPMORGAN_API_SECRET=CHANGE_ME
JPMORGAN_CLIENT_ID=CHANGE_ME
JPMORGAN_ENVIRONMENT=production
JPMORGAN_API_URL=https://api.jpmorgan.com/v1
JPMORGAN_OAUTH_URL=https://oauth.jpmorgan.com
JPMORGAN_WEBHOOK_SECRET=CHANGE_ME

# ============================================
# QUICKBOOKS INTEGRATION
# ============================================
QUICKBOOKS_CLIENT_ID=CHANGE_ME
QUICKBOOKS_CLIENT_SECRET=CHANGE_ME
QUICKBOOKS_REDIRECT_URI=https://heaven-on-earth.owlbangroup.com/auth/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production
QUICKBOOKS_API_URL=https://quickbooks.api.intuit.com

# ============================================
# PLAID INTEGRATION (Banking)
# ============================================
PLAID_CLIENT_ID=CHANGE_ME
PLAID_SECRET=CHANGE_ME
PLAID_ENVIRONMENT=production
PLAID_PRODUCTS=auth,transactions,identity
PLAID_COUNTRY_CODES=US,HT

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================
BLOCKCHAIN_NETWORK=mainnet
BLOCKCHAIN_NODE_URL=https://mainnet.infura.io/v3/CHANGE_ME
BLOCKCHAIN_PRIVATE_KEY=CHANGE_ME
BLOCKCHAIN_CONTRACT_ADDRESS=CHANGE_ME
BLOCKCHAIN_GAS_LIMIT=300000
BLOCKCHAIN_GAS_PRICE=auto

# Web3 Provider
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/CHANGE_ME

# ============================================
# AI SERVICES
# ============================================
# NVIDIA AI
NVIDIA_API_KEY=CHANGE_ME
NVIDIA_API_URL=https://api.nvidia.com/v1

# OpenAI (for NLP)
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Google Cloud AI
GOOGLE_CLOUD_PROJECT_ID=CHANGE_ME
GOOGLE_CLOUD_KEY_FILE=/secrets/google-cloud-key.json

# AWS AI Services
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1

# ============================================
# EMAIL SERVICES
# ============================================
# SendGrid
SENDGRID_API_KEY=CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@owlbangroup.com
SENDGRID_FROM_NAME=OWLBAN GROUP - Heaven on Earth

# Email Templates
EMAIL_TEMPLATE_UBI_PAYMENT=d-CHANGE_ME
EMAIL_TEMPLATE_EDUCATION_ENROLLMENT=d-CHANGE_ME
EMAIL_TEMPLATE_COMPLIANCE_WARNING=d-CHANGE_ME
EMAIL_TEMPLATE_SUSPENSION=d-CHANGE_ME

# ============================================
# SMS SERVICES (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=CHANGE_ME

# ============================================
# PAYMENT PROCESSING
# ============================================
# Stripe (Backup Payment Processor)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# PayPal
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_MODE=live

# ============================================
# CLOUD STORAGE
# ============================================
# AWS S3
S3_BUCKET_NAME=heaven-on-earth-prod
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME

# Document Storage
DOCUMENTS_BUCKET=heaven-on-earth-documents
BIOMETRIC_BUCKET=heaven-on-earth-biometric
CERTIFICATES_BUCKET=heaven-on-earth-certificates

# ============================================
# CDN & ASSETS
# ============================================
CDN_URL=https://cdn.owlbangroup.com
STATIC_ASSETS_URL=https://assets.owlbangroup.com
DASHBOARD_URL=https://heaven-on-earth.owlbangroup.com

# ============================================
# MONITORING & LOGGING
# ============================================
# Datadog
DATADOG_API_KEY=CHANGE_ME
DATADOG_APP_KEY=CHANGE_ME
DATADOG_SITE=datadoghq.com

# Sentry (Error Tracking)
SENTRY_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# CloudWatch
CLOUDWATCH_LOG_GROUP=/aws/heaven-on-earth/production
CLOUDWATCH_LOG_STREAM=application

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=https://heaven-on-earth.owlbangroup.com,https://admin.owlbangroup.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ============================================
# SSL/TLS CERTIFICATES
# ============================================
SSL_CERT_PATH=/etc/ssl/certs/heaven-on-earth.crt
SSL_KEY_PATH=/etc/ssl/private/heaven-on-earth.key
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_S3_BUCKET=heaven-on-earth-backups
BACKUP_ENCRYPTION_KEY=CHANGE_ME

# ============================================
# COMPLIANCE & AUDIT
# ============================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=2555
COMPLIANCE_CHECK_SCHEDULE=0 0 * * *

# ============================================
# PERFORMANCE OPTIMIZATION
# ============================================
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CACHE_TTL=3600
MAX_REQUEST_SIZE=50mb
REQUEST_TIMEOUT=30000

# ============================================
# WORKER PROCESSES
# ============================================
WORKER_PROCESSES=auto
WORKER_CONNECTIONS=1024
KEEPALIVE_TIMEOUT=65

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_UBI_ENABLED=true
FEATURE_EDUCATION_ENABLED=true
FEATURE_COMPLIANCE_ENABLED=true
FEATURE_PMC_ENABLED=true
FEATURE_BLOCKCHAIN_ENABLED=true
FEATURE_AI_ENABLED=true
FEATURE_BIOMETRIC_ENABLED=true

