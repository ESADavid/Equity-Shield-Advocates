# OSCAR BROOME REVENUE - Production Environment Configuration
# Version: 1.0.0
# IMPORTANT: Replace all placeholder values with actual production credentials

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=3000
ALLOWED_ORIGINS=https://oscar-broome-revenue.com,https://www.oscar-broome-revenue.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
MONGODB_URI=mongodb://admin:CHANGE_ME@localhost:27017/oscar-broome-production?authSource=admin&replicaSet=rs0&ssl=true
DB_USERNAME=admin
DB_PASSWORD=CHANGE_ME
DB_NAME=oscar-broome-production
DB_HOST=localhost
DB_PORT=27017
DB_REPLICA_SET=rs0
DB_SSL=true
DB_AUTH_SOURCE=admin
DB_AUTH_MECHANISM=SCRAM-SHA-256

# Connection Pool Settings
DB_MAX_POOL_SIZE=20
DB_MIN_POOL_SIZE=5
DB_CONNECTION_TIMEOUT=30000
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000
DB_MAX_RETRIES=5
DB_RETRY_DELAY=1000
DB_RECONNECT_ON_FAILURE=true

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=CHANGE_ME_TO_A_SECURE_64_CHARACTER_HEX_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_A_SECURE_64_CHARACTER_HEX_STRING
MFA_SECRET=CHANGE_ME_TO_A_SECURE_32_CHARACTER_HEX_STRING
ADMIN_OVERRIDE_CODE=CHANGE_ME_TO_A_SECURE_CODE
SESSION_TIMEOUT=3600000
MAX_SESSIONS_PER_USER=5
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# =============================================================================
# JPMORGAN PAYMENT CONFIGURATION
# =============================================================================
JPMORGAN_CLIENT_ID=YOUR_JPMORGAN_CLIENT_ID
JPMORGAN_CLIENT_SECRET=YOUR_JPMORGAN_CLIENT_SECRET
JPMORGAN_MERCHANT_ID=YOUR_JPMORGAN_MERCHANT_ID
JPMORGAN_TERMINAL_ID=YOUR_JPMORGAN_TERMINAL_ID
JPMORGAN_BASE_URL=https://api.payments.jpmorgan.com
JPMORGAN_ORGANIZATION_ID=YOUR_ORGANIZATION_ID
JPMORGAN_PROJECT_ID=YOUR_PROJECT_ID

# =============================================================================
# QUICKBOOKS CONFIGURATION
# =============================================================================
QUICKBOOKS_ACCESS_TOKEN=YOUR_QUICKBOOKS_ACCESS_TOKEN
QUICKBOOKS_REFRESH_TOKEN=YOUR_QUICKBOOKS_REFRESH_TOKEN
QUICKBOOKS_COMPANY_ID=YOUR_QUICKBOOKS_COMPANY_ID
QUICKBOOKS_CLIENT_ID=YOUR_QUICKBOOKS_CLIENT_ID
QUICKBOOKS_CLIENT_SECRET=YOUR_QUICKBOOKS_CLIENT_SECRET
QUICKBOOKS_BASE_URL=https://quickbooks.api.intuit.com

# =============================================================================
# STRIPE PAYMENT CONFIGURATION
# =============================================================================
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# =============================================================================
# PLAID CONFIGURATION
# =============================================================================
PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID
PLAID_SECRET=YOUR_PLAID_SECRET
PLAID_ENV=sandbox

# =============================================================================
# EMAIL/SMS CONFIGURATION
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
SMTP_FROM=Oscar Broome Revenue <noreply@oscar-broome-revenue.com>
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# =============================================================================
# OVERRIDE SYSTEM CONFIGURATION
# =============================================================================
EMERGENCY_OVERRIDE_CODE=CHANGE_ME_TO_A_SECURE_CODE
ADMIN_OVERRIDE_CODE=CHANGE_ME_TO_A_SECURE_CODE
MAX_OVERRIDE_ATTEMPTS=3
OVERRIDE_WINDOW_MINUTES=15
REQUIRE_ADDITIONAL_AUTH=true
NOTIFICATION_EMAILS=admin@oscar-broome-revenue.com

# =============================================================================
# MONITORING & LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_QUERY_MONITORING=false

# =============================================================================
# BLACKBOX AI CONFIGURATION
# =============================================================================
BLACKBOX_REPO_URL=https://github.com/your-org/oscar-broome-revenue
BLACKBOX_MODEL=claude-3-5-sonnet-20241022
BLACKBOX_MAX_TOKENS=8192
BLACKBOX_TEMPERATURE=0.7
