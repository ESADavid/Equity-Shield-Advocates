# OSCAR BROOME REVENUE - Production Environment Template&#10;# Copy to .env.production and fill in your secrets&#10;&#10;# === CORE ===&#10;NODE_ENV=production&#10;PORT=3000&#10;&#10;# === DATABASE ===&#10;MONGODB_URI=mongodb://admin:${MONGODB_PASSWORD}@mongodb:27017/oscar-broome-production?authSource=admin&#10;MONGODB_PASSWORD=your_strong_mongo_password&#10;&#10;# === CACHE ===&#10;REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379&#10;REDIS_PASSWORD=your_redis_password&#10;&#10;# === PAYMENTS ===&#10;STRIPE_SECRET_KEY=sk_live_...&#10;JPMORGAN_CLIENT_ID=your_jpm_client_id&#10;JPMORGAN_CLIENT_SECRET=your_jpm_client_secret&#10;JPMORGAN_MERCHANT_ID=your_merchant_id&#10;JPMORGAN_TERMINAL_ID=your_terminal_id&#10;&#10;# === NOTIFICATIONS ===&#10;SMTP_HOST=smtp.gmail.com&#10;SMTP_PORT=587&#10;SMTP_USER=your_email@gmail.com&#10;SMTP_PASS=your_app_password&#10;TWILIO_ACCOUNT_SID=AC...&#10;TWILIO_AUTH_TOKEN=your_twilio_token&#10;TWILIO_PHONE_NUMBER=+1234567890&#10;SENDGRID_API_KEY=SG....&#10;&#10;# === MONITORING ===&#10;GRAFANA_PASSWORD=your_grafana_admin_pass&#10;&#10;# === AI/BLACKBOX ===&#10;BLACKBOX_API_KEY=bb_ai_...&#10;BLACKBOX_REPO_URL=https://github.com/yourusername/OSCAR-BROOME-REVENUE.git&#10;BLACKBOX_BRANCH=main&#10;&#10;# === SECURITY ===&#10;JWT_SECRET=your_very_long_jwt_secret_key_here&#10;SKIP_DATABASE=false&#10;ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000&#10;&#10;# === DOCKER ===&#10;MONGO_INITDB_ROOT_PASSWORD=${MONGODB_PASSWORD}&#10;REDIS_PASSWORD=${REDIS_PASSWORD}
