{
  "name": "oscar-broome-revenue-override",
  "version": "2.0.0",
  "description": "Oscar Broome Revenue System with Transaction Override Capabilities",
  "main": "server-enhanced.js",
  "type": "module",
  "scripts": {
    "start": "node server-enhanced.js",
    "dev": "nodemon server-enhanced.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:staging": "NODE_ENV=staging jest --testPathPattern=staging",
    "test:treasury": "node -e \"import('./comprehensive_treasury_test.js').then(m => m.runComprehensiveTreasuryTests()).catch(console.error)\"",
    "test:integration": "node comprehensive_integration_test.js",
    "test:jpmorgan": "node -e \"import('./comprehensive_jpmorgan_test.js').then(m => m.runComprehensiveTests()).catch(console.error)\"",
    "test:merchant": "node -e \"import('./comprehensive_merchant_test_updated.js').then(m => m.runComprehensiveMerchantTests()).catch(console.error)\"",
    "test:payroll": "node -e \"import('./comprehensive_payroll_test_updated.js').then(m => m.runComprehensivePayrollTests()).catch(console.error)\"",
    "test:staging:full": "npm run test:treasury && npm run test:integration && npm run test:jpmorgan && npm run test:merchant && npm run test:payroll && npm run test:staging",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "build": "babel src --out-dir dist --copy-files",
    "build:staging": "NODE_ENV=staging npm run build",
    "migrate": "node scripts/migrate.js",
    "migrate:staging": "NODE_ENV=staging npm run migrate",
    "deploy:staging": "node staging_deployment.js",
    "start:staging": "NODE_ENV=staging npm start",
    "docker:build:staging": "docker build -f Dockerfile.staging -t oscar-broome-revenue:staging .",
    "docker:run:staging": "docker run -p 3001:3000 --env-file .env.staging oscar-broome-revenue:staging",
    "frontend:start": "serve -s frontend -l 5173"
  },
  "keywords": [
    "revenue",
    "transaction",
    "override",
    "audit",
    "oscar-broome",
    "treasury",
    "jpmorgan"
  ],
  "author": "Oscar Broome Revenue Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.21.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mathjs": "^14.8.1",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "nodemailer": "^7.0.6",
    "puppeteer": "^24.18.0",
    "redis": "^4.6.0",
    "socket.io": "^4.8.1",
    "stripe": "^18.5.0",
    "twilio": "^5.8.2",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.3",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/winston": "^2.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.1",
    "nodemon": "^2.0.20",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
